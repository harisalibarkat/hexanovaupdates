# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# ─── Database ─────────────────────────────────────────────────────────────────
# Set automatically by Docker Compose. Override only for external databases.
DATABASE_URL=postgresql://hexanova:hexanova_pass@localhost:5432/hexanovaupdates

# ─── Redis ────────────────────────────────────────────────────────────────────
# Set automatically by Docker Compose. Override only for external Redis.
REDIS_URL=redis://localhost:6379

# ─── AI Content Generation ────────────────────────────────────────────────────
# Required. Get a free key at https://console.groq.com/
GROQ_API_KEY=gsk_your-key-here

# ─── Cron Protection ──────────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret-key

# ─── Images (optional — fallback chain always resolves) ──────────────────────
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# https://www.pexels.com/api/
PEXELS_API_KEY=

# ─── Advertising (optional) ───────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_ID=ca-pub-0000000000000000

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=HexaNovaUpdates

# ─── SMTP ─────────────────────────────────────────────────────────────────────
# Configured in the Admin Panel → Settings (stored in database).
# These env vars are NOT used directly — configure SMTP via the admin UI.
